         }
      },
      {
        "type": "toggle",
        "label": "Battery Value visible",
        "messageKey": "EnableBattery",
        "defaultValue": true
      },
      {
        "type": "toggle",
        "label": "Foreground lines visible",
        "messageKey": "EnableLines",
        "defaultValue": true
      },
      {
